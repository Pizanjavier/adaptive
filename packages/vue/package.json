{
  "name": "@adaptive-bundle/vue",
  "publishConfig": {
    "access": "public"
  },
  "version": "0.3.0",
  "description": "Vue adapter for adaptive loading — ship different components to high and low-end devices with adaptive(), composables, and AdaptiveHigh/Low.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "peerDependencies": {
    "@adaptive-bundle/core": "workspace:*",
    "vue": ">=3.3.0"
  },
  "devDependencies": {
    "@adaptive-bundle/core": "workspace:*",
    "vue": "^3.4.0"
  },
  "sideEffects": false,
  "keywords": [
    "adaptive-loading",
    "device-aware",
    "bundle-optimization",
    "performance",
    "adaptive-bundle",
    "vue",
    "vue3",
    "lazy-loading",
    "conditional-rendering",
    "code-splitting",
    "composables",
    "defineAsyncComponent"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Pizanjavier/adaptive.git",
    "directory": "packages/vue"
  },
  "homepage": "https://github.com/Pizanjavier/adaptive/tree/main/packages/vue",
  "bugs": {
    "url": "https://github.com/Pizanjavier/adaptive/issues"
  }
}
