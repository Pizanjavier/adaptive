{
  "name": "@adaptive/next",
  "version": "0.1.0",
  "description": "Next.js integration for Adaptive — Webpack plugin for device-aware bundle optimization",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "peerDependencies": {
    "@adaptive/core": "workspace:*",
    "@adaptive/react": "workspace:*",
    "@adaptive/vite-plugin": "workspace:*",
    "next": ">=13.0.0"
  },
  "devDependencies": {
    "@adaptive/core": "workspace:*",
    "@adaptive/react": "workspace:*",
    "@adaptive/vite-plugin": "workspace:*"
  },
  "sideEffects": false
}
