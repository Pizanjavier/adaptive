{
  "name": "@adaptive-bundle/nuxt",
  "publishConfig": {
    "access": "public"
  },
  "version": "0.1.0",
  "description": "Nuxt module for device-aware bundle optimization — auto-configures Vite plugin and Nitro middleware for server-side tier resolution.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "peerDependencies": {
    "@adaptive-bundle/core": "workspace:*",
    "@adaptive-bundle/vite-plugin": "workspace:*",
    "nuxt": ">=3.0.0"
  },
  "devDependencies": {
    "@adaptive-bundle/core": "workspace:*",
    "@adaptive-bundle/vite-plugin": "workspace:*"
  },
  "sideEffects": false,
  "keywords": [
    "adaptive-loading",
    "device-aware",
    "bundle-optimization",
    "performance",
    "adaptive-bundle",
    "nuxt",
    "nuxt3",
    "nitro",
    "ssr",
    "server-side-rendering",
    "client-hints",
    "middleware"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Pizanjavier/adaptive.git",
    "directory": "packages/nuxt"
  },
  "homepage": "https://github.com/Pizanjavier/adaptive/tree/main/packages/nuxt",
  "bugs": {
    "url": "https://github.com/Pizanjavier/adaptive/issues"
  }
}
