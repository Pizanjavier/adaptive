{
  "name": "@adaptive-bundle/devtools",
  "publishConfig": {
    "access": "public"
  },
  "version": "0.1.0",
  "description": "Browser overlay and dev server dashboard for Adaptive — debug and simulate device tiers",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "peerDependencies": {
    "@adaptive-bundle/core": "workspace:*"
  },
  "devDependencies": {
    "@adaptive-bundle/core": "workspace:*"
  },
  "sideEffects": false
}
