{
  "name": "@adaptive-bundle/devtools",
  "publishConfig": {
    "access": "public"
  },
  "version": "0.3.0",
  "description": "Browser overlay and dev server dashboard for Adaptive — inspect device tier, probe values, boundary decisions, and simulate tiers in real time.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "peerDependencies": {
    "@adaptive-bundle/core": "workspace:*"
  },
  "devDependencies": {
    "@adaptive-bundle/core": "workspace:*"
  },
  "sideEffects": false,
  "keywords": [
    "adaptive-loading",
    "device-aware",
    "bundle-optimization",
    "performance",
    "adaptive-bundle",
    "devtools",
    "developer-tools",
    "debugging",
    "browser-overlay",
    "tier-simulator",
    "vite-dashboard"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Pizanjavier/adaptive.git",
    "directory": "packages/devtools"
  },
  "homepage": "https://github.com/Pizanjavier/adaptive/tree/main/packages/devtools",
  "bugs": {
    "url": "https://github.com/Pizanjavier/adaptive/issues"
  }
}
