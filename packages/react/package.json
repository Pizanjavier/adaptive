{
  "name": "@adaptive-bundle/react",
  "publishConfig": {
    "access": "public"
  },
  "version": "0.1.0",
  "description": "React adapter for adaptive loading — ship different components to high and low-end devices with adaptive(), Adaptive.High/Low, and hooks.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "peerDependencies": {
    "@adaptive-bundle/core": "workspace:*",
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "devDependencies": {
    "@adaptive-bundle/core": "workspace:*",
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "react": "^18.0.0",
    "react-dom": "^18.0.0"
  },
  "sideEffects": false,
  "keywords": [
    "adaptive-loading",
    "device-aware",
    "bundle-optimization",
    "performance",
    "adaptive-bundle",
    "react",
    "lazy-loading",
    "conditional-rendering",
    "code-splitting",
    "react-hooks",
    "suspense",
    "error-boundary"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Pizanjavier/adaptive.git",
    "directory": "packages/react"
  },
  "homepage": "https://github.com/Pizanjavier/adaptive/tree/main/packages/react",
  "bugs": {
    "url": "https://github.com/Pizanjavier/adaptive/issues"
  }
}
