{
  "name": "@adaptive-bundle/core",
  "publishConfig": {
    "access": "public"
  },
  "version": "0.1.0",
  "description": "Lightweight device detection engine — hardware scoring, tier resolution, and caching for adaptive loading. Zero dependencies, ~3KB gzipped.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./server": {
      "import": {
        "types": "./dist/server.d.ts",
        "default": "./dist/server.js"
      },
      "require": {
        "types": "./dist/server.d.cts",
        "default": "./dist/server.cjs"
      }
    },
    "./testing": {
      "import": {
        "types": "./dist/testing.d.ts",
        "default": "./dist/testing.js"
      },
      "require": {
        "types": "./dist/testing.d.cts",
        "default": "./dist/testing.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "sideEffects": false,
  "keywords": [
    "adaptive-loading",
    "device-aware",
    "bundle-optimization",
    "performance",
    "adaptive-bundle",
    "device-detection",
    "hardware-scoring",
    "tier-resolution",
    "client-hints",
    "navigator-api",
    "device-memory",
    "cpu-cores",
    "gpu-detection"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Pizanjavier/adaptive.git",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/Pizanjavier/adaptive/tree/main/packages/core",
  "bugs": {
    "url": "https://github.com/Pizanjavier/adaptive/issues"
  }
}
