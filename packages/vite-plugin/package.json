{
  "name": "@adaptive-bundle/vite-plugin",
  "publishConfig": {
    "access": "public"
  },
  "version": "0.1.0",
  "description": "Vite plugin for device-aware bundle optimization",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "bin": {
    "adaptive": "./dist/cli/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "vite": "^5.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0"
  },
  "sideEffects": false
}
